<?xml version='1.0' encoding='ISO-8859-1'?>
<OpenGeoSysProject>
    <meshes>
        <mesh axially_symmetric="true">combined_fracture_mesh.vtu</mesh>
        <mesh axially_symmetric="true">rectangle_bottom.vtu</mesh>
        <mesh axially_symmetric="true">rectangle_top.vtu</mesh>
        <mesh axially_symmetric="true">rectangle_well.vtu</mesh>
        <mesh axially_symmetric="true">rectangle_boundary_R.vtu</mesh>
        <mesh axially_symmetric="true">rectangle_fracture.vtu</mesh>
        <mesh axially_symmetric="true">rectangle_intersection_point.vtu</mesh>
    </meshes>
    <curves>
